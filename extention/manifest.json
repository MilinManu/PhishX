{
  "manifest_version": 3,
  "name": "PhishX – Phishing Website Detector",
  "version": "1.1.0",
  "description": "AI-powered phishing website detector using the PhishX backend (BERT + XGBoost).",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:5000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "PhishX – Check this site"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"],
      "run_at": "document_idle"
    }
  ]
}
